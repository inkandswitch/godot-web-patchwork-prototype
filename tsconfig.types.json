{
    "compilerOptions": {
      "allowJs": true,
      "checkJs": false,
      "declaration": true,
      "emitDeclarationOnly": true,
      "declarationMap": false,
      "outDir": "types/js",
      "module": "ESNext",
      "target": "ESNext",
      "moduleResolution": "bundler",
      "skipLibCheck": true
    },
    "module": "system",
    "include": ["js/**/*.js"],
    "exclude": ["node_modules"],
    // put everything into one file in `out/godot_types.d.ts`
    "outDir": "types/"
}